{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend: Next.js dev",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm dev",
            "cwd": "${workspaceFolder}/frontend"
        },
        {
            "name": "Frontend: Node (Server-side Debug)",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "restart": true,
            "cwd": "${workspaceFolder}/frontend",
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/frontend/node_modules/**"
            ],
            "sourceMaps": true,
            "protocol": "inspector"
        },
        {
            "name": "Frontend: Chrome (Browser Debug)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///*": "${webRoot}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Frontend: Debug (Server + Browser)",
            "configurations": [
                "Frontend: Next.js dev",
                "Frontend: Chrome (Browser Debug)"
            ],
            "stopOnEntry": false
        }
    ]
}