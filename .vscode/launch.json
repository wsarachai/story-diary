{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend: Next.js dev",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm dev",
            "cwd": "${workspaceFolder}/frontend"
        },
        {
            "name": "Frontend: Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend"
        },
        {
            "name": "Backend: API debug",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm debug",
            "cwd": "${workspaceFolder}/backend"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Frontend + Backend",
            "configurations": [
                "Frontend: Next.js dev",
                "Backend: API debug"
            ]
        }
    ]
}