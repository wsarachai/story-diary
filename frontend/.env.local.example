# ── MongoDB connection ──────────────────────────────────────────────────────
# Full connection URI (takes priority over the individual vars below)
MONGODB_URI=

# Individual vars (used only when MONGODB_URI is not set)
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CLUSTER_HOST=
MONGODB_QUERY=
MONGODB_DB_NAME=

# ── Database mode ───────────────────────────────────────────────────────────
# "mongo" = MongoDB Atlas (default for dev/prod)
# "memory" = in-memory store (default when NODE_ENV=test)
# DB_MODE=mongo

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Root admin ──────────────────────────────────────────────────────────────
# Phone number of the bootstrap root admin. The account that registers with
# this number is treated as rootAdmin (full admin + user management). This is
# the ONLY way to mint a root admin — if unset, no root admin exists and the
# user-management page is inaccessible. Register this number first on deploy.
# Example: ROOT_ADMIN_TEL=0812345678
ROOT_ADMIN_TEL=
