# ── MongoDB connection ──────────────────────────────────────────────────────
# Full connection URI (takes priority over the individual vars below)
MONGODB_URI=

# Individual vars (used only when MONGODB_URI is not set)
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CLUSTER_HOST=
MONGODB_QUERY=
MONGODB_DB_NAME=

# ── Database mode ───────────────────────────────────────────────────────────
# "mongo" = MongoDB Atlas (default for dev/prod)
# "memory" = in-memory store (default when NODE_ENV=test)
# DB_MODE=mongo

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Admin users ─────────────────────────────────────────────────────────────
# Comma-separated user IDs that should be treated as admins.
# Used as a fallback for existing accounts that predate the role field.
# Example: ADMIN_USER_IDS=uuid-of-user-1,uuid-of-user-2
ADMIN_USER_IDS=
