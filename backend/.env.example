# ── MongoDB connection ──────────────────────────────────────────────────────
MONGODB_USERNAME=sarachaii_db_user
MONGODB_PASSWORD=replace-with-your-password
MONGODB_CLUSTER_HOST=cluster0.563g7gd.mongodb.net
MONGODB_QUERY=retryWrites=true&w=majority&appName=Cluster0

# ── Database names ──────────────────────────────────────────────────────────
MONGODB_DB_NAME=story-diary
MONGODB_TEST_DB_NAME=story-diary-test

# ── Database mode ───────────────────────────────────────────────────────────
# "mongo" = MongoDB Atlas (default for dev/prod)
# "memory" = in-memory store (default when NODE_ENV=test)
# DB_MODE=mongo

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
